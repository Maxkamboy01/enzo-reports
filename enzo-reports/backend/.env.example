# Server
PORT=3001
JWT_SECRET=change_this_secret_key

# SAP B1 Service Layer — Cement database
SAP_CEMENT_URL=https://your-sap-server:50000/b1s/v1
SAP_CEMENT_COMPANY=ENZO_CEMENT
SAP_CEMENT_USER=manager
SAP_CEMENT_PASS=your_password

# SAP B1 Service Layer — Shifer database
SAP_SHIFER_URL=https://your-sap-server:50000/b1s/v1
SAP_SHIFER_COMPANY=ENZO_SHIFER
SAP_SHIFER_USER=manager
SAP_SHIFER_PASS=your_password

# SAP B1 Service Layer — JBI database
SAP_JBI_URL=https://your-sap-server:50000/b1s/v1
SAP_JBI_COMPANY=ENZO_JBI
SAP_JBI_USER=manager
SAP_JBI_PASS=your_password
